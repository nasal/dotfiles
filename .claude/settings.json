{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(vercel --prod *)",
      "Bash(vercel deploy --prod *)",
      "Bash(wrangler deploy *)",
      "Bash(eas submit *)",
      "Bash(eas build --auto-submit *)",
      "Bash(stripe *)",
      "Bash(bunx prisma migrate deploy *)",
      "Bash(bunx drizzle-kit push *)",
      "Bash(pnpm exec prisma migrate deploy *)",
      "Bash(alembic upgrade *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git push * -f *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit * --no-verify *)",
      "Bash(git commit -n *)",
      "Bash(git commit * -n *)",
      "Bash(cat .env*)",
      "Bash(cat ~/.env*)",
      "Bash(source .env*)",
      "Bash(source ~/.env*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./secrets/**)",
      "Read(~/.env)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.config/gh/hosts.yml)"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/dotfiles/.claude/hooks/guardrails.ts",
            "timeout": 5,
            "statusMessage": "Checking hard guardrails"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "default",
  "teammateMode": "in-process"
}
